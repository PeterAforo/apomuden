  "api_routes": {
    "auth": [
      { "method": "POST", "path": "/api/auth/register", "description": "Register citizen with phone/email" },
      { "method": "POST", "path": "/api/auth/login", "description": "Login with OTP/email/Ghana Card" },
      { "method": "POST", "path": "/api/auth/verify-otp", "description": "Verify phone OTP" },
      { "method": "POST", "path": "/api/auth/refresh", "description": "Refresh JWT token" },
      { "method": "POST", "path": "/api/auth/2fa/setup", "description": "Enable 2FA for Ministry roles" },
      { "method": "POST", "path": "/api/auth/2fa/verify", "description": "Verify 2FA code" }
    ],
    "facilities": [
      { "method": "GET", "path": "/api/facilities", "description": "Search/browse facilities with geospatial filters" },
      { "method": "GET", "path": "/api/facilities/[slug]", "description": "Get facility profile by slug" },
      { "method": "POST", "path": "/api/facilities", "description": "Register new facility (auth: any)" },
      { "method": "PATCH", "path": "/api/facilities/[id]", "description": "Update facility profile (auth: facility_admin)" },
      { "method": "POST", "path": "/api/facilities/[id]/approve", "description": "Approve facility (auth: ministry)" },
