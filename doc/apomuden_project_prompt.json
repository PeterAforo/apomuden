    "nhis": [
      { "method": "GET", "path": "/api/nhis/verify/[nhisNumber]", "description": "Verify NHIS active status" },
      { "method": "GET", "path": "/api/nhis/coverage/[serviceId]", "description": "Check NHIS coverage for a service" }
    ],
