      { "method": "PATCH", "path": "/api/facilities/[id]/tier", "description": "Assign/update tier (auth: ministry)" },
      { "method": "GET", "path": "/api/facilities/[id]/analytics", "description": "Facility analytics (auth: facility_admin)" },
      { "method": "GET", "path": "/api/facilities/nearby", "description": "Get facilities near lat/lng with radius" },
      { "method": "GET", "path": "/api/facilities/compare", "description": "Compare up to 3 facilities" }
    ],
    "services": [
      { "method": "GET", "path": "/api/facilities/[id]/services", "description": "List services for a facility" },
      { "method": "POST", "path": "/api/facilities/[id]/services", "description": "Add service (auth: facility_admin)" },
      { "method": "PATCH", "path": "/api/services/[id]", "description": "Update service/pricing (auth: facility_admin)" },
      { "method": "DELETE", "path": "/api/services/[id]", "description": "Remove service (auth: facility_admin)" },
      { "method": "GET", "path": "/api/service-taxonomy", "description": "Get standardised service taxonomy" },
      { "method": "GET", "path": "/api/services/search", "description": "Search services across facilities with price comparison" }
    ],
    "emergency": [
      { "method": "POST", "path": "/api/emergency", "description": "Create emergency request (auth: citizen)" },
      { "method": "GET", "path": "/api/emergency/[id]", "description": "Get emergency status" },
      { "method": "PATCH", "path": "/api/emergency/[id]/status", "description": "Update emergency status (auth: facility/admin)" },
      { "method": "GET", "path": "/api/emergency/[id]/track", "description": "Get ambulance live tracking" },
      { "method": "GET", "path": "/api/ambulances/available", "description": "Get available ambulances near location" }
    ],
    "alerts": [
      { "method": "GET", "path": "/api/alerts", "description": "Get public alerts (filterable by region/district)" },
      { "method": "POST", "path": "/api/alerts", "description": "Create alert draft (auth: ministry)" },
      { "method": "POST", "path": "/api/alerts/[id]/approve", "description": "Approve alert for broadcast (auth: ministry_admin)" },
      { "method": "POST", "path": "/api/alerts/[id]/broadcast", "description": "Send alert to citizens (auth: ministry_admin)" },
      { "method": "GET", "path": "/api/alerts/[id]/delivery-stats", "description": "Alert delivery statistics" },
      { "method": "GET", "path": "/api/alerts/regional/[regionId]", "description": "Get alerts for a specific region" }
    ],
    "diagnosis": [
      { "method": "POST", "path": "/api/diagnosis-reports", "description": "Submit diagnosis report (auth: facility)" },
      { "method": "GET", "path": "/api/diagnosis-reports", "description": "Get reports (auth: facility for own, ministry for all)" },
      { "method": "GET", "path": "/api/diagnosis/trends", "description": "Disease trends by region/time (auth: ministry)" },
      { "method": "GET", "path": "/api/diagnosis/anomalies", "description": "Detected anomalies (auth: ministry)" },
      { "method": "GET", "path": "/api/diagnosis/heatmap", "description": "Geospatial disease density data" }
    ],
    "reviews": [
