{
  "project": {
    "name": "Apomuden Health Portal",
    "tagline": "Ghana's National Digital Health Platform",
    "description": "A comprehensive digital health platform for the Ghana Ministry of Health that enables citizens to discover healthcare facilities, compare services and pricing, request emergency services, and receive health alerts — while equipping the Ministry with real-time disease surveillance and outbreak detection capabilities.",
    "version": "1.0.0",
    "owner": "Ghana Ministry of Health",
    "branding": {
      "primary_color": "#1B5E20",
      "secondary_color": "#2E7D32",
      "accent_color": "#C62828",
      "logo_text": "Apomuden",
      "tagline": "Your Health, Closer",
      "languages": ["en", "tw", "ga", "ee", "ha"]
    }
  },

  "tech_stack": {
    "frontend": {
      "framework": "Next.js 14+ (App Router)",
      "language": "TypeScript",
      "styling": "Tailwind CSS 3.4+",
      "ui_library": "shadcn/ui + Radix Primitives",
      "maps": "Mapbox GL JS",
      "state_management": "Zustand + React Query (TanStack Query)",
      "forms": "React Hook Form + Zod validation",
      "charts": "Recharts + D3.js (heatmaps)",
      "icons": "Lucide React",
      "i18n": "next-intl"
    },
    "backend": {
      "runtime": "Node.js 20 LTS",
      "api": "Next.js API Routes + tRPC",
      "database": "PostgreSQL 16 + PostGIS",
      "orm": "Prisma 5+",
      "auth": "NextAuth.js v5 (Auth.js)",
      "cache": "Redis (Upstash)",
      "queue": "BullMQ",
      "search": "Meilisearch",
      "file_storage": "AWS S3 / Cloudflare R2",
      "sms_gateway": "Hubtel API (primary) + Arkesel (failover)",
      "email": "Resend"
    },
    "ai_ml": {
      "llm_provider": "Anthropic Claude API",
      "ml_framework": "Python FastAPI microservice",
      "ml_libraries": ["scikit-learn", "pandas", "statsmodels"],
      "chatbot_architecture": "RAG (Retrieval-Augmented Generation)",
      "vector_store": "Pinecone or pgvector"
    },
    "devops": {
      "hosting_frontend": "Vercel",
      "hosting_backend": "AWS (Cape Town region) or Hetzner",
      "ci_cd": "GitHub Actions",
      "monitoring": "Sentry (errors) + PostHog (analytics)",
      "containerization": "Docker + Docker Compose",
      "infrastructure_as_code": "Terraform"
    }
  },

  "database_schema": {
    "models": [
      {
        "name": "User",
        "description": "All platform users (citizens, facility staff, ministry officials)",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "email", "type": "String", "unique": true, "nullable": true },
          { "name": "phone", "type": "String", "unique": true },
          { "name": "name", "type": "String" },
          { "name": "role", "type": "Enum", "values": ["GUEST", "CITIZEN", "FACILITY_ADMIN", "FACILITY_STAFF", "FACILITY_VIEWER", "DISTRICT_OFFICER", "REGIONAL_DIRECTOR", "MINISTRY_ADMIN", "ANALYST", "SUPER_ADMIN"] },
          { "name": "ghana_card_id", "type": "String", "nullable": true, "unique": true },
          { "name": "nhis_number", "type": "String", "nullable": true },
          { "name": "date_of_birth", "type": "Date", "nullable": true },
          { "name": "gender", "type": "Enum", "values": ["MALE", "FEMALE", "OTHER"], "nullable": true },
          { "name": "blood_type", "type": "String", "nullable": true },
          { "name": "region_id", "type": "UUID", "relation": "Region", "nullable": true },
          { "name": "district_id", "type": "UUID", "relation": "District", "nullable": true },
          { "name": "latitude", "type": "Float", "nullable": true },
          { "name": "longitude", "type": "Float", "nullable": true },
          { "name": "avatar_url", "type": "String", "nullable": true },
          { "name": "is_verified", "type": "Boolean", "default": false },
          { "name": "two_factor_enabled", "type": "Boolean", "default": false },
          { "name": "notification_preferences", "type": "JSON", "default": {} },
          { "name": "created_at", "type": "DateTime" },
          { "name": "updated_at", "type": "DateTime" }
        ]
      },
      {
        "name": "EmergencyContact",
        "description": "Citizen emergency contacts",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "user_id", "type": "UUID", "relation": "User" },
          { "name": "name", "type": "String" },
          { "name": "phone", "type": "String" },
          { "name": "relationship", "type": "String" }
        ]
      },
      {
        "name": "Region",
        "description": "Ghana's 16 administrative regions",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "name", "type": "String" },
          { "name": "code", "type": "String", "unique": true },
          { "name": "boundary_geojson", "type": "JSON", "nullable": true }
        ]
      },
      {
        "name": "District",
        "description": "Districts within regions",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "region_id", "type": "UUID", "relation": "Region" },
          { "name": "name", "type": "String" },
          { "name": "constituency", "type": "String", "nullable": true },
          { "name": "boundary_geojson", "type": "JSON", "nullable": true }
        ]
      },
      {
        "name": "Facility",
        "description": "Health institutions and facilities",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "name", "type": "String" },
          { "name": "slug", "type": "String", "unique": true },
          { "name": "type", "type": "Enum", "values": ["HOSPITAL", "CLINIC", "PHARMACY", "DIAGNOSTIC_CENTRE", "MATERNITY_HOME", "CHPS_COMPOUND", "POLYCLINIC", "HEALTH_CENTRE"] },
          { "name": "tier", "type": "Enum", "values": ["FIVE_STAR", "FOUR_STAR", "THREE_STAR", "TWO_STAR", "ONE_STAR"], "nullable": true },
          { "name": "license_number", "type": "String", "unique": true },
          { "name": "license_document_url", "type": "String" },
          { "name": "status", "type": "Enum", "values": ["PENDING", "APPROVED", "SUSPENDED", "REJECTED"], "default": "PENDING" },
          { "name": "rejection_reason", "type": "String", "nullable": true },
          { "name": "description", "type": "Text", "nullable": true },
          { "name": "address", "type": "String" },
          { "name": "latitude", "type": "Float" },
          { "name": "longitude", "type": "Float" },
          { "name": "location", "type": "PostGIS_Point", "description": "PostGIS geography point for geospatial queries" },
          { "name": "region_id", "type": "UUID", "relation": "Region" },
          { "name": "district_id", "type": "UUID", "relation": "District" },
          { "name": "phone", "type": "String" },
          { "name": "email", "type": "String", "nullable": true },
          { "name": "website", "type": "String", "nullable": true },
          { "name": "nhis_accepted", "type": "Boolean", "default": false },
          { "name": "emergency_capable", "type": "Boolean", "default": false },
          { "name": "ambulance_available", "type": "Boolean", "default": false },
          { "name": "operating_hours", "type": "JSON", "description": "{ monday: { open: '08:00', close: '17:00' }, ... }" },
          { "name": "bed_count", "type": "Int", "nullable": true },
          { "name": "icu_beds_available", "type": "Int", "nullable": true },
          { "name": "photos", "type": "String[]", "default": [] },
          { "name": "average_rating", "type": "Float", "default": 0 },
          { "name": "total_reviews", "type": "Int", "default": 0 },
          { "name": "verified_at", "type": "DateTime", "nullable": true },
          { "name": "verified_by", "type": "UUID", "relation": "User", "nullable": true },
          { "name": "created_at", "type": "DateTime" },
          { "name": "updated_at", "type": "DateTime" }
        ]
      },
      {
        "name": "FacilityStaff",
        "description": "Maps users to facilities with roles",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "user_id", "type": "UUID", "relation": "User" },
          { "name": "facility_id", "type": "UUID", "relation": "Facility" },
          { "name": "role", "type": "Enum", "values": ["ADMIN", "STAFF", "VIEWER"] },
          { "name": "invited_by", "type": "UUID", "relation": "User", "nullable": true },
          { "name": "is_active", "type": "Boolean", "default": true },
          { "name": "created_at", "type": "DateTime" }
        ]
      },
      {
        "name": "ServiceTaxonomy",
        "description": "Standardised health service categories (GHS-aligned)",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "name", "type": "String" },
          { "name": "category", "type": "String" },
          { "name": "description", "type": "String", "nullable": true },
          { "name": "standard_code", "type": "String", "nullable": true }
        ]
      },
      {
        "name": "Service",
        "description": "Services offered by facilities with pricing",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "facility_id", "type": "UUID", "relation": "Facility" },
          { "name": "taxonomy_id", "type": "UUID", "relation": "ServiceTaxonomy", "nullable": true },
          { "name": "name", "type": "String" },
          { "name": "category", "type": "String" },
          { "name": "description", "type": "String", "nullable": true },
          { "name": "price_ghs", "type": "Decimal" },
          { "name": "nhis_covered", "type": "Enum", "values": ["YES", "PARTIAL", "NO"], "default": "NO" },
          { "name": "nhis_copay_ghs", "type": "Decimal", "nullable": true },
          { "name": "duration_minutes", "type": "Int", "nullable": true },
          { "name": "department", "type": "String", "nullable": true },
          { "name": "is_custom", "type": "Boolean", "default": false, "description": "True if not from standard taxonomy" },
          { "name": "is_active", "type": "Boolean", "default": true },
          { "name": "created_at", "type": "DateTime" },
          { "name": "updated_at", "type": "DateTime" }
        ]
      },
      {
        "name": "ServicePriceHistory",
        "description": "Audit trail for service price changes",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "service_id", "type": "UUID", "relation": "Service" },
          { "name": "old_price_ghs", "type": "Decimal" },
          { "name": "new_price_ghs", "type": "Decimal" },
          { "name": "changed_by", "type": "UUID", "relation": "User" },
          { "name": "changed_at", "type": "DateTime" }
        ]
      },
      {
        "name": "DiagnosisReport",
        "description": "Aggregated diagnosis data from facilities for surveillance",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "facility_id", "type": "UUID", "relation": "Facility" },
          { "name": "disease_code", "type": "String", "description": "ICD-10 code" },
          { "name": "disease_name", "type": "String" },
          { "name": "case_count", "type": "Int" },
          { "name": "period_start", "type": "Date" },
          { "name": "period_end", "type": "Date" },
          { "name": "period_type", "type": "Enum", "values": ["DAILY", "WEEKLY", "MONTHLY"] },
          { "name": "demographics", "type": "JSON", "description": "{ age_groups: { '0-4': 5, '5-14': 8 }, gender: { male: 7, female: 6 } }" },
          { "name": "severity", "type": "JSON", "description": "{ mild: 5, moderate: 4, severe: 3, critical: 1 }" },
          { "name": "outcomes", "type": "JSON", "description": "{ recovered: 8, admitted: 3, referred: 1, deceased: 1 }" },
          { "name": "is_anomalous", "type": "Boolean", "default": false },
          { "name": "submitted_by", "type": "UUID", "relation": "User" },
          { "name": "created_at", "type": "DateTime" }
        ]
      },
      {
        "name": "Alert",
        "description": "Health alerts and advisories from Ministry",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "title", "type": "String" },
          { "name": "body", "type": "Text" },
          { "name": "severity", "type": "Enum", "values": ["INFO", "WARNING", "CRITICAL", "EMERGENCY"] },
          { "name": "scope", "type": "Enum", "values": ["NATIONAL", "REGIONAL", "DISTRICT", "CONSTITUENCY"] },
          { "name": "target_region_ids", "type": "UUID[]", "nullable": true },
          { "name": "target_district_ids", "type": "UUID[]", "nullable": true },
          { "name": "disease_code", "type": "String", "nullable": true },
          { "name": "precautions", "type": "Text", "nullable": true },
          { "name": "status", "type": "Enum", "values": ["DRAFT", "PENDING_APPROVAL", "APPROVED", "SENT", "EXPIRED"], "default": "DRAFT" },
          { "name": "channels", "type": "String[]", "default": ["push", "sms", "portal"], "description": "Delivery channels" },
          { "name": "sms_message", "type": "String", "nullable": true, "description": "Shortened version for SMS (160 chars)" },
          { "name": "auto_generated", "type": "Boolean", "default": false },
          { "name": "source_report_ids", "type": "UUID[]", "nullable": true },
          { "name": "created_by", "type": "UUID", "relation": "User" },
          { "name": "approved_by", "type": "UUID", "relation": "User", "nullable": true },
          { "name": "sent_at", "type": "DateTime", "nullable": true },
          { "name": "expires_at", "type": "DateTime", "nullable": true },
          { "name": "created_at", "type": "DateTime" }
        ]
      },
      {
        "name": "EmergencyRequest",
        "description": "Emergency service requests from citizens",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "citizen_id", "type": "UUID", "relation": "User" },
          { "name": "type", "type": "Enum", "values": ["MEDICAL", "ACCIDENT", "MATERNITY", "FIRE_BURNS", "OTHER"] },
          { "name": "description", "type": "Text", "nullable": true },
          { "name": "latitude", "type": "Float" },
          { "name": "longitude", "type": "Float" },
          { "name": "callback_phone", "type": "String" },
          { "name": "status", "type": "Enum", "values": ["PENDING", "ACKNOWLEDGED", "DISPATCHED", "EN_ROUTE", "ARRIVED", "TRANSPORTING", "RESOLVED", "CANCELLED"], "default": "PENDING" },
          { "name": "assigned_facility_id", "type": "UUID", "relation": "Facility", "nullable": true },
          { "name": "assigned_ambulance_id", "type": "UUID", "relation": "Ambulance", "nullable": true },
          { "name": "response_time_seconds", "type": "Int", "nullable": true },
          { "name": "resolved_at", "type": "DateTime", "nullable": true },
          { "name": "notes", "type": "Text", "nullable": true },
          { "name": "created_at", "type": "DateTime" }
        ]
      },
      {
        "name": "Ambulance",
        "description": "Ambulance fleet for emergency dispatch",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "facility_id", "type": "UUID", "relation": "Facility" },
          { "name": "registration_number", "type": "String", "unique": true },
          { "name": "type", "type": "Enum", "values": ["BASIC", "ADVANCED", "NEONATAL"] },
          { "name": "status", "type": "Enum", "values": ["AVAILABLE", "ON_CALL", "OUT_OF_SERVICE"], "default": "AVAILABLE" },
          { "name": "current_latitude", "type": "Float", "nullable": true },
          { "name": "current_longitude", "type": "Float", "nullable": true },
          { "name": "driver_name", "type": "String", "nullable": true },
          { "name": "driver_phone", "type": "String", "nullable": true }
        ]
      },
      {
        "name": "Review",
        "description": "Citizen reviews and ratings for facilities",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "citizen_id", "type": "UUID", "relation": "User" },
          { "name": "facility_id", "type": "UUID", "relation": "Facility" },
          { "name": "rating", "type": "Int", "description": "1-5 stars" },
          { "name": "text", "type": "Text", "nullable": true },
          { "name": "facility_response", "type": "Text", "nullable": true },
          { "name": "facility_responded_at", "type": "DateTime", "nullable": true },
          { "name": "status", "type": "Enum", "values": ["ACTIVE", "FLAGGED", "REMOVED"], "default": "ACTIVE" },
          { "name": "created_at", "type": "DateTime" },
          { "name": "updated_at", "type": "DateTime" }
        ]
      },
      {
        "name": "AuditLog",
        "description": "System-wide audit trail",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "user_id", "type": "UUID", "relation": "User" },
          { "name": "action", "type": "String", "description": "e.g., FACILITY_APPROVED, ALERT_SENT, SERVICE_PRICE_UPDATED" },
          { "name": "entity_type", "type": "String" },
          { "name": "entity_id", "type": "UUID" },
          { "name": "details", "type": "JSON", "nullable": true },
          { "name": "ip_address", "type": "String", "nullable": true },
          { "name": "user_agent", "type": "String", "nullable": true },
          { "name": "created_at", "type": "DateTime" }
        ]
      },
      {
        "name": "Notification",
        "description": "User notification queue",
        "fields": [
          { "name": "id", "type": "UUID", "primary": true },
          { "name": "user_id", "type": "UUID", "relation": "User" },
          { "name": "alert_id", "type": "UUID", "relation": "Alert", "nullable": true },
          { "name": "title", "type": "String" },
          { "name": "body", "type": "String" },
          { "name": "channel", "type": "Enum", "values": ["PUSH", "SMS", "EMAIL", "IN_APP"] },
          { "name": "status", "type": "Enum", "values": ["PENDING", "SENT", "DELIVERED", "FAILED"] },
          { "name": "sent_at", "type": "DateTime", "nullable": true },
          { "name": "read_at", "type": "DateTime", "nullable": true },
          { "name": "created_at", "type": "DateTime" }
        ]
      }
    ]
  },

  "pages": {
    "public": [
      {
        "path": "/",
        "name": "Landing Page",
        "description": "Hero with search bar, emergency SOS button, active alerts ticker, featured facilities, disease advisory banner for user's region",
        "components": ["HeroSearch", "EmergencySOSButton", "AlertsTicker", "FeaturedFacilities", "RegionalAdvisoryBanner", "QuickStats", "Footer"]
      },
      {
        "path": "/facilities",
        "name": "Facility Discovery",
        "description": "Interactive map with facility markers (colour-coded by tier), search bar, advanced filters (distance, tier, type, service, price range, NHIS, open now), toggle between map and list view",
        "components": ["MapView", "FacilityListView", "SearchBar", "FilterPanel", "FacilityCard", "PriceComparisonModal"]
      },
      {
        "path": "/facility/[slug]",
        "name": "Facility Profile",
        "description": "Full facility details: verified/tier badges, photos gallery, address with embedded map, operating hours with live open/closed status, service catalogue with prices and NHIS coverage, ratings and reviews, contact details, request appointment button",
        "components": ["FacilityHeader", "PhotoGallery", "ServiceTable", "PriceFilter", "NHISBadge", "ReviewsList", "ReviewForm", "LocationMap", "ContactCard"]
      },
      {
        "path": "/emergency",
        "name": "Emergency Request",
        "description": "Streamlined emergency flow: auto-GPS capture, emergency type selection, brief description, phone confirmation, nearest facility display, ambulance tracking (Phase 4)",
        "components": ["EmergencyForm", "LocationCapture", "NearestFacilityCard", "AmbulanceTracker"]
      },
      {
        "path": "/alerts",
        "name": "Health Alerts",
        "description": "Public health advisories filterable by region/district, severity badges, precaution details, historical alert archive",
        "components": ["AlertsList", "AlertCard", "RegionFilter", "SeverityFilter", "AlertDetail"]
      },
      {
        "path": "/compare",
        "name": "Facility Comparison",
        "description": "Side-by-side comparison of up to 3 facilities: services, prices, ratings, distance, NHIS coverage",
        "components": ["ComparisonTable", "FacilitySelector", "PriceHighlight"]
      },
      {
        "path": "/about",
        "name": "About",
        "description": "About Apomuden, Ministry of Health information, how it works, FAQ",
        "components": ["AboutContent", "HowItWorks", "FAQ"]
      },
      {
        "path": "/auth/login",
        "name": "Login",
        "description": "Phone OTP login, email login, Ghana Card login option",
        "components": ["LoginForm", "OTPInput", "SocialAuth"]
      },
      {
        "path": "/auth/register",
        "name": "Registration",
        "description": "Citizen registration with phone verification, profile setup, location selection, NHIS number entry",
        "components": ["RegistrationForm", "OTPVerification", "LocationPicker", "NHISInput"]
      },
      {
        "path": "/auth/facility-register",
        "name": "Facility Registration",
        "description": "Multi-step facility onboarding: basic info, license upload, location pin, operating hours, initial services",
        "components": ["MultiStepForm", "LicenseUpload", "MapPinSelector", "HoursEditor", "ServiceAdder"]
      }
    ],
    "citizen_dashboard": [
      {
        "path": "/dashboard",
        "name": "Citizen Home",
        "description": "Personalised dashboard: nearby active alerts, favourite facilities, recent activity, health advisory for user's district",
        "components": ["AlertBanner", "FavouriteFacilities", "RecentActivity", "LocalAdvisory", "QuickActions"]
      },
      {
        "path": "/dashboard/profile",
        "name": "Profile Settings",
        "description": "Manage personal info, NHIS details, emergency contacts, notification preferences, location settings",
        "components": ["ProfileForm", "NHISSection", "EmergencyContacts", "NotificationPreferences", "LocationSettings"]
      },
      {
        "path": "/dashboard/emergency-history",
        "name": "Emergency History",
        "description": "Past emergency requests with status timeline",
        "components": ["EmergencyList", "StatusTimeline"]
      },
      {
        "path": "/dashboard/symptom-checker",
        "name": "AI Symptom Checker",
        "description": "Natural language symptom input, AI analysis results, facility recommendations, first-aid guidance, disclaimer",
        "components": ["SymptomInput", "AIAnalysis", "FacilityRecommendations", "FirstAidGuidance", "DisclaimerBanner"]
      }
    ],
    "facility_dashboard": [
      {
        "path": "/facility-admin",
        "name": "Facility Dashboard",
        "description": "Overview: profile completeness, service count, recent reviews, monthly analytics, alerts relevant to facility's region",
        "components": ["OverviewStats", "ProfileCompleteness", "RecentReviews", "MonthlyChart", "RegionalAlerts"]
      },
      {
        "path": "/facility-admin/profile",
        "name": "Manage Profile",
        "description": "Edit facility details, upload photos, update operating hours, manage contact info",
        "components": ["FacilityProfileForm", "PhotoUploader", "HoursEditor", "ContactForm"]
      },
      {
        "path": "/facility-admin/services",
        "name": "Service Management",
        "description": "Add/edit/remove services, set pricing, indicate NHIS coverage, bulk import services from taxonomy",
        "components": ["ServiceList", "ServiceForm", "TaxonomyBrowser", "BulkImport", "PriceHistory"]
      },
      {
        "path": "/facility-admin/reports",
        "name": "Diagnosis Reports",
        "description": "Submit diagnosis data, view submission history, anomaly flags, ICD-10 code search",
        "components": ["ReportForm", "ICD10Search", "ReportHistory", "AnomalyFlag"]
      },
      {
        "path": "/facility-admin/reviews",
        "name": "Reviews Management",
        "description": "View citizen reviews, respond to reviews, flag inappropriate reviews",
        "components": ["ReviewList", "ResponseForm", "FlagButton"]
      },
      {
        "path": "/facility-admin/staff",
        "name": "Staff Management",
        "description": "Invite staff, assign roles, deactivate accounts",
        "components": ["StaffList", "InviteForm", "RoleSelector"]
      },
      {
