      { "method": "GET", "path": "/api/admin/audit-logs", "description": "Audit log search" },
      { "method": "GET", "path": "/api/admin/reports/export", "description": "Export analytics reports (PDF/CSV)" }
    ]
  },

  "phases": {
    "phase_1": {
      "name": "Foundation (MVP)",
      "timeline": "Months 1-6",
      "features": [
        "Facility registration with multi-step form and license upload",
        "Ministry verification workflow (approve/reject/request amendments)",
        "Service catalogue with standardised taxonomy and pricing",
        "Facility tier classification (1-5 star system)",
        "Citizen geolocation-based facility search with map and list views",
        "Advanced search filters (distance, tier, type, service, price range)",
        "Individual facility profile pages with service/pricing details",
        "Basic public alerts page",
        "Responsive mobile-first design",
        "SEO-optimised public pages"
      ]
    },
    "phase_2": {
      "name": "Engagement",
      "timeline": "Months 7-10",
      "features": [
        "Citizen registration and authentication (phone OTP, email, Ghana Card)",
        "Citizen profile with NHIS number, location, emergency contacts",
        "Emergency service request system with GPS capture",
        "NHIS insurance integration (verify status, check coverage per service)",
        "Ratings and reviews system with facility response capability",
        "Push notifications for health alerts and updates",
        "Facility comparison tool (side-by-side pricing)",
        "Favourites and saved facilities",
        "Notification preferences management",
        "Price discrepancy reporting by citizens"
      ]
    },
    "phase_3": {
      "name": "Intelligence",
      "timeline": "Months 11-16",
      "features": [
        "Diagnosis reporting pipeline with ICD-10 code support",
        "Statistical anomaly detection on diagnosis data streams",
        "Automated outbreak flagging with Ministry notification",
        "Ministry analytics dashboard with disease heatmaps",
        "Trend analysis with time-series visualisations",
        "Alert broadcasting system (push + SMS + portal)",
        "SMS/USSD gateway for feature phone access",
        "USSD menus: find facility, receive alerts, request emergency",
        "Regional and district health officer dashboards",
        "Exportable reports (PDF, CSV) for policy planning",
        "Audit logging system"
      ]
    },
    "phase_4": {
      "name": "AI & Advanced",
      "timeline": "Months 17-24",
      "features": [
        "AI symptom checker with natural language input",
        "Smart facility recommendations (location + budget + insurance + condition)",
        "Multilingual chatbot (English, Twi, Ga, Ewe, Hausa)",
        "Predictive outbreak modelling with ML",
        "Automated alert drafting from anomaly data",
        "Ambulance dispatch system with real-time GPS tracking",
        "Ambulance operator mobile PWA interface",
        "Telemedicine consultation booking and video integration",
        "Real-time bed/ICU/resource availability tracker",
        "QR code facility profiles",
        "Offline PWA with cached facility data",
        "Voice-to-text symptom input"
      ]
    }
  },

  "rbac": {
    "roles": [
      {
        "name": "GUEST",
        "description": "Unauthenticated visitor",
        "permissions": ["facilities:browse", "facilities:view", "services:view", "alerts:view_public", "facilities:search"]
      },
      {
        "name": "CITIZEN",
        "description": "Registered citizen",
        "permissions": ["facilities:browse", "facilities:view", "facilities:favourite", "services:view", "services:compare", "alerts:view_public", "alerts:receive_personalised", "emergency:create", "emergency:view_own", "reviews:create", "reviews:flag", "nhis:verify_own", "ai:symptom_check", "ai:chat", "profile:manage_own", "notifications:manage_own"]
      },
      {
        "name": "FACILITY_ADMIN",
        "description": "Manages a specific facility",
        "permissions": ["facility:manage_profile", "facility:manage_services", "facility:manage_staff", "facility:view_analytics", "facility:respond_reviews", "diagnosis:submit", "diagnosis:view_own", "resources:update", "ambulance:manage"]
      },
      {
        "name": "FACILITY_STAFF",
        "description": "Staff member at a facility",
        "permissions": ["facility:view_profile", "diagnosis:submit", "resources:update"]
      },
      {
        "name": "FACILITY_VIEWER",
        "description": "Read-only facility dashboard access",
        "permissions": ["facility:view_profile", "facility:view_analytics"]
      },
      {
        "name": "DISTRICT_OFFICER",
        "description": "District Health Officer",
        "permissions": ["facilities:view_district", "facilities:verify_district", "alerts:draft_district", "diagnosis:view_district", "analytics:view_district"]
      },
      {
        "name": "REGIONAL_DIRECTOR",
        "description": "Regional Health Director",
        "permissions": ["facilities:manage_region", "facilities:verify_region", "facilities:assign_tier_region", "alerts:manage_region", "diagnosis:view_region", "analytics:view_region", "users:manage_region"]
      },
      {
        "name": "MINISTRY_ADMIN",
        "description": "Ministry of Health administrator",
        "permissions": ["facilities:manage_all", "facilities:assign_tier", "alerts:manage_all", "alerts:broadcast", "diagnosis:view_all", "analytics:view_all", "users:manage_all", "ai:draft_alert"]
      },
      {
        "name": "ANALYST",
        "description": "Read-only analytics access",
        "permissions": ["analytics:view_all", "diagnosis:view_all", "reports:export"]
      },
      {
        "name": "SUPER_ADMIN",
        "description": "Full system access",
        "permissions": ["*"]
      }
    ]
  },

