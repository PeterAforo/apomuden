      { "method": "POST", "path": "/api/reviews/[id]/flag", "description": "Flag review (auth: any authenticated)" }
    ],
    "ai": [
      { "method": "POST", "path": "/api/ai/symptom-check", "description": "AI symptom analysis (auth: citizen)" },
      { "method": "POST", "path": "/api/ai/chat", "description": "Chatbot conversation (auth: any)" },
      { "method": "GET", "path": "/api/ai/recommendations", "description": "Smart facility recommendations (auth: citizen)" },
      { "method": "POST", "path": "/api/ai/draft-alert", "description": "AI-generated alert draft from anomaly data (auth: ministry)" }
