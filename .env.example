# =============================================================================
# APOMUDEN HEALTH PORTAL - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in the values

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/apomuden?schema=public"

# -----------------------------------------------------------------------------
# AUTHENTICATION (NextAuth.js v5)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your-nextauth-secret-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# MAPBOX (for facility maps)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk.your-mapbox-public-token"

# -----------------------------------------------------------------------------
# REDIS (for caching and session management)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
# Or for Upstash:
# UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# -----------------------------------------------------------------------------
# FILE STORAGE (AWS S3 or Cloudflare R2)
# -----------------------------------------------------------------------------
S3_BUCKET_NAME="apomuden-uploads"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_REGION="af-south-1"
S3_ENDPOINT="" # Leave empty for AWS, set for R2 or other S3-compatible

# -----------------------------------------------------------------------------
# SMS GATEWAY (mNotify)
# -----------------------------------------------------------------------------
MNOTIFY_API_KEY="your-mnotify-api-key"
MNOTIFY_SENDER_ID="Apomuden"

# -----------------------------------------------------------------------------
# PUSHER (Real-time & Push Notifications)
# -----------------------------------------------------------------------------
# Pusher Channels (for WebSocket real-time features)
NEXT_PUBLIC_PUSHER_KEY="your-pusher-app-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_SECRET="your-pusher-secret"

# Pusher Beams (for push notifications)
NEXT_PUBLIC_PUSHER_BEAMS_INSTANCE_ID="dee70e22-5739-4328-8311-6b49e327d2a6"
PUSHER_BEAMS_SECRET_KEY="your-pusher-beams-secret-key"

# -----------------------------------------------------------------------------
# VIDEO CALLS (Daily.co)
# -----------------------------------------------------------------------------
DAILY_API_KEY="your-daily-api-key"
NEXT_PUBLIC_DAILY_DOMAIN="your-daily-domain"

# -----------------------------------------------------------------------------
# AI / LLM (Anthropic Claude)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# -----------------------------------------------------------------------------
# SEARCH (Meilisearch)
# -----------------------------------------------------------------------------
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# -----------------------------------------------------------------------------
# NHIS INTEGRATION
# -----------------------------------------------------------------------------
NHIA_API_BASE_URL="https://api.nhis.gov.gh"
NHIA_API_KEY="your-nhia-api-key"

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS
# -----------------------------------------------------------------------------
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project"
NEXT_PUBLIC_POSTHOG_KEY="phc_your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------------------------------
# EMAIL (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your-resend-api-key"

# -----------------------------------------------------------------------------
# OPTIONAL SERVICES
# -----------------------------------------------------------------------------
# Google Maps (alternative to Mapbox)
# GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Pinecone (for vector search in AI features)
# PINECONE_API_KEY="your-pinecone-api-key"
# PINECONE_ENVIRONMENT="us-east-1-aws"
# PINECONE_INDEX="apomuden-health"
